<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="flashcard.app.controller.AddDeckController"
      spacing="10" alignment="CENTER_LEFT" prefWidth="320" prefHeight="320">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Set name:"/>
    <TextField fx:id="nameField"/>

    <Label text="Front text:"/>
    <HBox spacing="5">
        <TextField fx:id="frontField" prefWidth="200" HBox.hgrow="ALWAYS"/>
        <Button text="Browse..." onAction="#handleBrowse"/>
    </HBox>

    <Label text="Back text:"/>
    <TextField fx:id="backField"/>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button text="Add" onAction="#handleAdd"/>
        <Button text="Save" onAction="#handleSave"/>
    </HBox>

    <HBox alignment="CENTER_RIGHT">
        <Label fx:id="countLabel" text="Item count: 0"/>
    </HBox>

</VBox>