<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.text.TextFlow?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx"
            fx:controller="flashcard.app.controller.StudySessionController"
            prefHeight="700.0" prefWidth="500.0"
            style="-fx-background-color: #f9f9f9;">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 20 20 10 20;">
            <Button fx:id="backButton" text="← Back to Decklist" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 14px; -fx-text-fill: #555555;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="30" alignment="CENTER" style="-fx-padding: 0 40 40 40;">

            <VBox spacing="15" alignment="CENTER"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">

                <Label fx:id="frontTextLabel"  wrapText="true" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333333; -fx-text-alignment: center;"/>
            </VBox>

            <VBox spacing="10" alignment="CENTER_LEFT" maxWidth="380">
                <Label text="Type your answer:" style="-fx-text-fill: #777777; -fx-font-size: 14px; -fx-font-weight: bold;"/>

                <TextFlow fx:id="feedbackFlow" prefHeight="45"
                          style="-fx-background-color: #f0f0f0; -fx-background-radius: 6; -fx-padding: 5 10 5 10;"/>

                <TextField fx:id="answerField" promptText="Start typing..."
                           prefHeight="45"
                           style="-fx-font-size: 18px; -fx-background-radius: 8; -fx-padding: 0 12 0 12; -fx-font-family: 'Monospaced'"/>
            </VBox>

        </VBox>
    </center>
</BorderPane>